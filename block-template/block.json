{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "create-custom-wp-theme/{{block_slug}}",
    "version": "0.1.0",
    "title": "{{block_title}}",
    "category": "widgets",
    "icon": "smiley",
    "description": "Custom {{block_title}} block.",
    "supports": {
        "html": false
    },
    "textdomain": "{{block_slug}}",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css"
}